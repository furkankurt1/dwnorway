# Vipps ePayment API — https://portal.vipps.no
VIPPS_CLIENT_ID=
VIPPS_CLIENT_SECRET=
VIPPS_SUBSCRIPTION_KEY=
VIPPS_MERCHANT_SERIAL_NUMBER=
VIPPS_IS_TEST=false

# Stripe — https://dashboard.stripe.com/apikeys
# Secret key (server-side, NEVER expose in client bundle)
STRIPE_SECRET_KEY=sk_live_...
# Publishable key (client-side, safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook signing secret — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (contact form emails) — https://resend.com
RESEND_API_KEY=

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://dawahnorge.no
