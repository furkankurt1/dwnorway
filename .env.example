# Vipps ePayment API — https://portal.vipps.no
VIPPS_CLIENT_ID=
VIPPS_CLIENT_SECRET=
VIPPS_SUBSCRIPTION_KEY=
VIPPS_MERCHANT_SERIAL_NUMBER=
VIPPS_IS_TEST=false

# Stripe — https://dashboard.stripe.com/apikeys
# Secret key (server-side, NEVER expose in client bundle)
STRIPE_SECRET_KEY=sk_live_...
# Publishable key (client-side, safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook signing secret — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (contact form emails) — https://resend.com
RESEND_API_KEY=

# PayPal — https://developer.paypal.com/dashboard/applications
# Public (client-side) — enables the PayPal card on /donate
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# Server-side — required for order/subscription creation
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# "sandbox" for testing, unset/anything else = live
PAYPAL_ENV=live
# Optional: required only for monthly (recurring) PayPal donations
PAYPAL_MONTHLY_PLAN_ID=

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.dawahnorway.com

# Cloudflare Turnstile (contact form captcha)
# Dashboard → Turnstile → Add site → "Managed" mode → copy keys
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
